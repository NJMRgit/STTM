checklist_mark 2

fetch_file() {
    dest="$1"
    url="$2"
    if command -v curl >/dev/null 2>&1; then
        curl -fsSL "$url" -o "$dest"
    elif command -v wget >/dev/null 2>&1; then
        wget -q "$url" -O "$dest"
    else
        return 1
    fi
}

merge_script() {
    src="$1"; tgt="$2"
    ss=$(grep -n "^#get time" "$src" | head -1 | cut -d: -f1)
    tt=$(grep -n "^#get time" "$tgt" | head -1 | cut -d: -f1)
    [ -z "$ss" ] && return 1
    if [ -z "$tt" ]; then
        cp -p "$tgt" "$tgt.bak.$(date +%Y%m%d%H%M%S)" 2>/dev/null || true
        return 1
    fi
    awk -v ts="$tt" 'NR <= ts' "$tgt" > "$tgt.tmp" &&
    awk -v ss="$ss" 'NR > ss'  "$src" >> "$tgt.tmp" &&
    mv "$tgt.tmp" "$tgt"
}

cp_or_fetch() {
    file="$1"
    merge="${2:-no}"
    target_dir="$3"
    target="$target_dir/$file"
    if [ -f "$SCRIPT_DIR/$file" ]; then
        if [ "$merge" = "merge" ] && [ -f "$target" ]; then
            merge_script "$SCRIPT_DIR/$file" "$target" || cp "$SCRIPT_DIR/$file" "$target"
        else
            cp "$SCRIPT_DIR/$file" "$target"
        fi
    elif [ -n "$STTM_RAWBASE" ]; then
        if [ "$merge" = "merge" ] && [ -f "$target" ]; then
            tmp_src=$(mktemp /tmp/sttm.XXXXXX)
            fetch_file "$tmp_src" "$STTM_RAWBASE/$file" || { rm -f "$tmp_src"; return 1; }
            merge_script "$tmp_src" "$target" || cp "$tmp_src" "$target"
            rm -f "$tmp_src"
        else
            fetch_file "$target" "$STTM_RAWBASE/$file"
        fi
    else
        left_border "$NEXT_ROW"
        printf '\033[%s;2H  Warning: %s not found, skipping.\n' "$NEXT_ROW" "$file"
        NEXT_ROW=$((NEXT_ROW + 1))
        return 1
    fi
}

