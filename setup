#!/bin/sh

set -e

# Silent apply — no output
apply() {
    file="$1"; group="$2"; key="$3"; value="$4"
    [ -z "$value" ] && return
    case "$group" in
        *\]\[*)
            first=$(echo "$group" | sed 's/\]\[.*//')
            rest=$(echo "$group" | sed 's/^[^]]*\]\[//')
            kwriteconfig6 --file "$file" --group "$first" --group "$rest" --key "$key" "$value"
            ;;
        *)
            kwriteconfig6 --file "$file" --group "$group" --key "$key" "$value"
            ;;
    esac
}

# Type text with per-character delay
type_text() {
    str="$1"
    while [ -n "$str" ]; do
        c=$(printf '%s' "$str" | sed 's/\(.\).*/\1/')
        printf '%s' "$c"
        str=$(printf '%s' "$str" | sed 's/.//')
        sleep 0.004
    done
}

# Strip inline comment markers (whitespace must precede '#')
clean() {
    printf '%s\n' "$1" | sed 's/[[:space:]][[:space:]]*#.*//' | sed 's/[[:space:]]*$//'
}

# Run a command in the background with a spinner; print ✓ or ✗ by result
run_step() {
    "$@" >/dev/null 2>&1 &
    pid=$!
    while kill -0 "$pid" 2>/dev/null; do
        for c in $spinner_chars; do
            printf '\b%s' "$c"
            sleep 0.04
            kill -0 "$pid" 2>/dev/null || break 2
        done
    done
    if wait "$pid"; then
        printf '\b\033[32m✓\033[0m\n'
    else
        printf '\b\033[31m✗\033[0m\n'
        return 1
    fi
}

spinner_chars="- \\ | /"
NEXT_ROW=0
file_row=0
file_count=0
file_descs=""
config_summary=""
styles_summary=""
manager_summary=""
INSTALL_DIR=""

enter_fullscreen() {
    W=$(tput cols 2>/dev/null || echo 80)
    H=$(tput lines 2>/dev/null || echo 24)
    [ "$W" -lt 60 ] && W=60
    [ "$H" -lt 15 ] && H=15

    printf '\033[?1049h'
    printf '\033[?25l'

    # Animate border spreading from top-left corner
    printf '\033[1;1H┌'
    c=2
    m=$((W < H ? W : H))
    while [ "$c" -lt "$m" ]; do
        printf '\033[1;%sH─' "$c"
        printf '\033[%s;1H│' "$c"
        sleep 0.002
        c=$((c + 1))
    done
    while [ "$c" -lt "$W" ]; do
        printf '\033[1;%sH─' "$c"
        sleep 0.002
        c=$((c + 1))
    done
    [ "$W" -gt 1 ] && printf '\033[1;%sH┐' "$W"
    while [ "$c" -lt "$H" ]; do
        printf '\033[%s;1H│' "$c"
        sleep 0.002
        c=$((c + 1))
    done
    printf '\033[%s;1H└' "$H"
    d=2
    while [ "$d" -lt "$H" ]; do
        printf '\033[%s;%sH│' "$d" "$W"
        sleep 0.0015
        d=$((d + 1))
    done
    d=2
    while [ "$d" -lt "$W" ]; do
        printf '\033[%s;%sH─' "$H" "$d"
        sleep 0.0015
        d=$((d + 1))
    done
    printf '\033[%s;%sH┘' "$H" "$W"

    # Animate header wipe top-to-bottom
    printf '\033[36m\033[2;2H███████╗ ████████╗ ████████╗ ███╗   ███╗\033[0m'; sleep 0.05
    printf '\033[36m\033[3;2H██╔════╝ ╚══██╔══╝ ╚══██╔══╝ ████╗ ████║\033[0m'; sleep 0.05
    printf '\033[36m\033[4;2H███████╗    ██║       ██║    ██╔████╔██║\033[0m'; sleep 0.05
    printf '\033[36m\033[5;2H╚════██║    ██║       ██║    ██║╚██╔╝██║\033[0m'; sleep 0.05
    printf '\033[36m\033[6;2H███████║    ██║       ██║    ██║ ╚═╝ ██║\033[0m'; sleep 0.05
    printf '\033[36m\033[7;2H╚══════╝    ╚═╝       ╚═╝    ╚═╝     ╚═╝\033[0m'; sleep 0.05
    printf '\033[36m\033[8;2H  Stoned Theme Manager — First Time Setup\033[0m'; sleep 0.05
    printf '\033[9;1H├'
    c=2; while [ "$c" -lt "$W" ]; do printf '─'; c=$((c + 1)); done
    printf '┤'
    NEXT_ROW=10

    # Clear content area rows 10 to H-1
    r=10
    while [ "$r" -lt "$H" ]; do
        printf '\033[%s;2H\033[K' "$r"
        printf '\033[%s;%sH│' "$r" "$W"
        r=$((r + 1))
    done
}

left_border() {
    printf '\033[%s;2H\033[K' "$1"
    printf '\033[%s;%sH│' "$1" "$W"
}

checklist_mark() {
    row=$((3 + $1))
    printf '\033[%s;%sH\033[32m✓\033[0m' "$row" "$((W - 23))"
}

section_header() {
    left_border "$NEXT_ROW"
    printf '\033[%s;2H\033[2m── %s\033[0m\n' "$NEXT_ROW" "$1"
    NEXT_ROW=$((NEXT_ROW + 1))
}

exit_fullscreen() {
    printf '\033[?25h'
    printf '\033[?1049l'
}

start_file() {
    file_row=$NEXT_ROW
    NEXT_ROW=$((NEXT_ROW + 1))
    left_border "$file_row"
    printf '\033[%s;2H  ' "$file_row"
    type_text "$1"
    printf ' '
    for c in $spinner_chars; do
        printf '\b%s' "$c"
        sleep 0.04
    done
    desc_count=0
    file_descs=""
}

add_desc() {
    desc_count=$((desc_count + 1))
    file_descs="$file_descs  - $1
"
    left_border "$NEXT_ROW"
    printf '\033[%s;2H  - %s' "$NEXT_ROW" "$1"
    NEXT_ROW=$((NEXT_ROW + 1))
    left_border "$file_row"
    printf '\033[%s;2H  %s ' "$file_row" "$current_file"
    for c in $spinner_chars; do
        printf '\b%s' "$c"
        sleep 0.04
    done
    sleep 0.15
}

finish_file() {
    left_border "$file_row"
    printf '\033[%s;2H  %s \033[32m✓\033[0m' "$file_row" "$1"
    config_summary="$config_summary
 ~/.config/$1 ($desc_count)
$file_descs"
    file_count=$((file_count + 1))
}

show_summary() {
    DIVIDER=$((W / 2 + 1))

    if [ "$install_mode" = skip ]; then
        left_data="  Files updated ($file_count):
$config_summary
  Styles/Colors applied:
$styles_summary"
    else
        left_data="  Files updated ($file_count):
$config_summary
  Styles/Colors applied:
$styles_summary
  Manager:
$manager_summary"
    fi

    if [ "$install_mode" = portable ]; then
        right_data="  Commands:
    ~/STTM/blsw morning|noon|afternoon|evening|night
    ~/STTM/blsw auto
    ~/STTM/blsw --fix
  GUI:
    ~/STTM/sttm
    python3 ~/STTM/sttm --portable
  Examples:
    ~/STTM/blsw morning    Manual theme
    ~/STTM/blsw auto       Time-based
    ~/STTM/blsw --fix      Rebuild effects
    ~/STTM/sttm            Launch GUI
  File locations:
    $INSTALL_DIR/sttm
    $INSTALL_DIR/blsw
    ~/.local/share/color-schemes/glassd.colors"
    elif [ "$install_mode" = local ]; then
        right_data="  Commands:
    blsw morning|noon|afternoon|evening|night
    blsw auto
    blsw --fix
  GUI:
    sttm
    python3 sttm --portable
  Examples:
    blsw morning        Manual theme
    blsw auto           Time-based
    blsw --fix          Rebuild effects
    sttm                Launch GUI
  File locations:
    $INSTALL_DIR/sttm
    $INSTALL_DIR/blsw
    ~/.local/share/color-schemes/glassd.colors"
    fi

    section_header "Summary"
    start_row=$NEXT_ROW

    if [ "$install_mode" = skip ]; then
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            left_border "$NEXT_ROW"
            printf '\033[%s;2H%s' "$NEXT_ROW" "$line"
            NEXT_ROW=$((NEXT_ROW + 1))
        done <<LEFTDATA
$left_data
LEFTDATA
        end_row=$((NEXT_ROW - 1))
    else
        left_count=$(printf '%s\n' "$left_data" | wc -l)
        right_count=$(printf '%s\n' "$right_data" | wc -l)
        max_rows=$left_count
        [ "$right_count" -gt "$max_rows" ] && max_rows=$right_count

        end_row=$((start_row + max_rows - 1))

        row=1
        while [ "$row" -le "$max_rows" ]; do
            r=$((start_row + row - 1))
            left_line=$(printf '%s\n' "$left_data" | sed -n "${row}p")
            right_line=$(printf '%s\n' "$right_data" | sed -n "${row}p")
            left_border "$r"
            printf '\033[%s;2H%s' "$r" "$left_line"
            printf '\033[%s;%sH│' "$r" "$DIVIDER"
            if [ -n "$right_line" ]; then
                printf '\033[%s;%sH%s' "$r" "$((DIVIDER + 2))" "$right_line"
            fi
            row=$((row + 1))
        done
        NEXT_ROW=$((end_row + 1))
    fi

    # Inner separator before exit prompt
    printf '\033[%s;1H├' "$NEXT_ROW"
    c=2; while [ "$c" -lt "$W" ]; do printf '─'; c=$((c + 1)); done
    printf '┤\n'
    NEXT_ROW=$((NEXT_ROW + 1))

    left_border "$NEXT_ROW"
    printf '\033[%s;2H  Press Enter to exit.' "$NEXT_ROW"
    read -r REPLY < /dev/tty || true
    exit_fullscreen
}

restore_screen() {
    printf '\033[?25h'
    printf '\033[?1049l'
}

on_signal() {
    restore_screen
    exit 1
}

if ! command -v kwriteconfig6 >/dev/null 2>&1; then
    echo "Error: kwriteconfig6 is required but was not found." >&2
    exit 1
fi

trap on_signal INT TERM TSTP
trap restore_screen EXIT

enter_fullscreen

row0=$NEXT_ROW
left_border "$NEXT_ROW"; NEXT_ROW=$((NEXT_ROW + 1))
left_border "$NEXT_ROW"; NEXT_ROW=$((NEXT_ROW + 1))
left_border "$NEXT_ROW"; NEXT_ROW=$((NEXT_ROW + 1))
left_border "$NEXT_ROW"; NEXT_ROW=$((NEXT_ROW + 1))
left_border "$NEXT_ROW"; NEXT_ROW=$((NEXT_ROW + 1))
left_border "$NEXT_ROW"; NEXT_ROW=$((NEXT_ROW + 1))
left_border "$NEXT_ROW"; NEXT_ROW=$((NEXT_ROW + 1))
left_border "$NEXT_ROW"; NEXT_ROW=$((NEXT_ROW + 1))
left_border "$NEXT_ROW"; NEXT_ROW=$((NEXT_ROW + 1))
left_border "$NEXT_ROW"; NEXT_ROW=$((NEXT_ROW + 1))
LINE1="  - Enable Glass'd color scheme"
LINE2="    + Custom Transparent Color Scheme"
LINE3="    + Required for Full Window Transparency"
LINE4="  - Enable Darkly Application Style"
LINE5="    + Required for Full Window Transparency"
LINE6="  - Change 4v3ngR/kwin-effects-glass settings and enable the effect"
LINE7="  - Change matinlotfali/KDE-Rounded-Corners settings and enable the effect"
LINE8="  - Change Plasma style to Iridescent-round"
LINE9="  - Change GTK Theme to we10x"
LINE10="  - Add Window rule for CSD shadow compatibility"
max_len=0
for l in "$LINE1" "$LINE2" "$LINE3" "$LINE4" "$LINE5" "$LINE6" "$LINE7" "$LINE8" "$LINE9" "$LINE10"; do
    ll=${#l}
    [ "$ll" -gt "$max_len" ] && max_len=$ll
done
col=$((max_len - 1))
while [ "$col" -ge 0 ]; do
    r=0
    for l in "$LINE1" "$LINE2" "$LINE3" "$LINE4" "$LINE5" "$LINE6" "$LINE7" "$LINE8" "$LINE9" "$LINE10"; do
        c=$(printf '%s' "$l" | cut -c $((col + 1)))
        [ -n "$c" ] && printf '\033[%s;%sH%s' "$((row0 + r))" "$((2 + col))" "$c"
        r=$((r + 1))
    done
    col=$((col - 1))
    sleep 0.001
done
left_border "$NEXT_ROW"
printf '\033[%s;2H  ' "$NEXT_ROW"
type_text "Continue? [Y/n]: "
read -r REPLY < /dev/tty
case "$REPLY" in
    [nN]|[nN][oO])
        printf '\033[%s;2H  Aborted.\n' "$NEXT_ROW"
        exit 0
        ;;
esac
printf '\n'
NEXT_ROW=$((NEXT_ROW + 1))
left_border "$NEXT_ROW"
printf '\033[%s;2H  Hide titlebars? [y/N]: ' "$NEXT_ROW"
read -r REPLY < /dev/tty
case "$REPLY" in
    [yY]|[yY][eE][sS]) hide_titlebars=true ;;
    *) hide_titlebars=false ;;
esac
NEXT_ROW=$((NEXT_ROW + 1))

# Animate checklist reveal top-to-bottom
printf '\033[3;%sH┌──────────────────────┐' "$((W - 25))"; sleep 0.05
printf '\033[4;%sH│ ○ Update Files       │' "$((W - 25))"; sleep 0.05
printf '\033[5;%sH│ ○ Apply styles/colors│' "$((W - 25))"; sleep 0.05
printf '\033[6;%sH│ ○ Install Manager    │' "$((W - 25))"; sleep 0.05
printf '\033[7;%sH└──────────────────────┘' "$((W - 25))"; sleep 0.05

# Bottom-to-top wipe of description text
r=$((NEXT_ROW - 1))
while [ "$r" -ge 10 ]; do
    printf '\033[%s;2H\033[K' "$r"
    printf '\033[%s;%sH│' "$r" "$W"
    r=$((r - 1))
    sleep 0.02
done

# Ensure config files exist before writing to them
for cfg in breezerc darklyrc kwinrc kwinrulesrc; do
    path="$HOME/.config/$cfg"
    if [ ! -f "$path" ]; then
        left_border "$NEXT_ROW"; printf '\033[%s;2H  Creating %s...\n' "$NEXT_ROW" "$cfg"; NEXT_ROW=$((NEXT_ROW + 1))
        touch "$path"
    fi
done

printf '\033[10;1H│\033[J'
r=11; while [ "$r" -lt "$H" ]; do
    printf '\033[%s;1H│' "$r"
    printf '\033[%s;%sH│' "$r" "$W"
    r=$((r + 1))
done
printf '\033[%s;1H└' "$H"; c=2; while [ "$c" -lt "$W" ]; do printf '─'; c=$((c + 1)); done; printf '┘'
left_border 10
printf '\033[10;2H\033[2m── Updating config files\033[0m\n'
NEXT_ROW=11

current_file=""
description=""

while IFS= read -r line || [ -n "$line" ]; do
    # Strip leading whitespace, skip empties and comments
    raw=$(printf "%s" "$line" | sed 's/^[[:space:]]*//')
    case "$raw" in
        ""|"#"*) continue ;;
    esac

    # Section header — file|group
    case "$raw" in
        \[*\])
            if [ -n "$description" ]; then
                add_desc "$description"
            fi
            description=""
            sect=$(echo "$raw" | sed 's/^\[\(.*\)\]$/\1/')
            file=$(echo "$sect" | sed 's/|.*//')
            group=$(echo "$sect" | sed 's/.*|//')
            if [ "$file" != "$current_file" ]; then
                if [ -n "$current_file" ]; then
                    finish_file "$current_file"
                fi
                start_file "$file"
                current_file="$file"
            fi
            continue
            ;;
    esac

    # key=value
    case "$raw" in
        *=*)
            key=$(printf '%s\n' "$raw" | sed 's/=.*//;s/[[:space:]]*$//')
            val=$(printf '%s\n' "$raw" | sed 's/^[^=]*=//')

            # --- description (printed after section is processed) ---
            if [ "$key" = "_description" ]; then
                description="$val"
                continue
            fi

            # --- hide titlebars prompt ---
            if printf '%s\n' "$val" | grep -q "enable hide titlebars"; then
                if $hide_titlebars; then
                    apply "$file" "$group" "$key" "true"
                else
                    apply "$file" "$group" "$key" "false"
                fi
                continue
            fi

            v=$(clean "$val")
            apply "$file" "$group" "$key" "$v"
            ;;
    esac
done <<'CONFIGS'
# ----------------------------------------------------------------
# Format: [file|group]
#         key=value
# Lines starting with # are skipped.
# Inline annotations are stripped.
# ----------------------------------------------------------------

[kwinrc|Effect-better-blur-dx]
BlurDecorations=true
BlurDocks=true
BlurMatching=false
BlurMenus=true
BlurNonMatching=true
BlurStrength=5
CornerRadius=8
RefractionCornerRadius=110
RefractionEdgeSize=30
RefractionMode=1
RefractionNormalPow=13
RefractionStrength=5
WindowClasses=gsr-ui

[kwinrc|Effect-blurplus]
_description=configure glass blur effect settings
BlurDecorations=true
BlurFinetune=5
BlurMatching=false
BlurNonMatching=true
BlurSaturationCompensation=false
BlurStrength=6
BottomCornerRadius=6
Brightness=0.85
DecorationBlurStrength=6
DecorationNoiseStrength=3
DockBlurStrength=3
DockNoiseStrength=0
EdgeLighting=true
EdgeLightingTooltip=true
FakeBlur=true
FakeBlurImage=
FakeBlurImageSourceCustom=true
FakeBlurImageSourceDesktopWallpaper=false
GlowColor=
MenuCornerRadius=11.5
NoiseStrength=3
OklabSaturation=true
RefractionNormalPow=22
RefractionRGBFringing=0
TintColor=#22222222
TopCornerRadius=6
WindowClasses=gsr-ui

[kwinrc|Plugins]
_description=adjust enabled desktop effects
blurEnabled=false
fadeEnabled=true
glassEnabled=true
scaleEnabled=false

[kwinrc|Round-Corners]
_description=configure rounded corners settings
ActiveShadowAlpha=170
ActiveShadowUseCustom=true
DisableOutlineMaximize=false
DisableOutlineTile=false
DisableRoundMaximize=false
DisableRoundTile=false
Exclusions=gsr-ui
InactiveCornerRadius=6
InactiveOutlineColor=55,55,55
InactiveOutlineThickness=4
InactiveSecondOutlineThickness=0
InactiveShadowColor=55,55,55
InactiveShadowSize=50
InactiveShadowUseCustom=true
OutlineColor=55,55,55
OutlineThickness=4
SecondOutlineThickness=0
ShadowColor=55,55,55
ShadowSize=50
Size=6
UseNativeDecorationShadows=false

[kwinrc|org.kde.kdecoration2]
_description=set window decoration theme
NoPlugin=false
library=org.kde.darkly
theme=Darkly

[kwinrulesrc|50a6fdb6-57ad-47da-aedd-67ff644f4ef5]
_description=add window rule for shadow compatibility
Description=Global Shadows (For Stoned Theme Manager)
noborderrule=2

[plasmarc|Theme]
_description=set plasma theme
name=Iridescent-round

[breezerc|Common]
_description=configure breeze outline settings
OutlineIntensity=OutlineOff

[breezerc|Windeco Exception 0]
_description=configure breeze window exception rules
BorderSize=0
Enabled=true
ExceptionPattern=.*
ExceptionType=0
HideTitleBar=false  # enable hide titlebars
Mask=0

[darklyrc|Common]
_description=configure darkly common settings
ButtonHeight=8
CornerRadius=7
FancyMargins=false
ShadowColor=20,50,42
ShadowStrength=51
SunkenEffect=true

[darklyrc|Style]
_description=configure darkly style settings
DisableDolphinUrlNavigatorBackground=false
DolphinSidebarOpacity=18
DolphinViewOpacity=18
MenuOpacity=20
TabBarOpacity=18
TabDrawHighlight=true

[darklyrc|Windeco]
_description=configure darkly window decoration settings
RoundedCorners=false

[darklyrc|Windeco Exception 0]
_description=configure darkly window exception rules
BorderSize=0
Enabled=true
ExceptionPattern=.*
ExceptionType=0
HideTitleBar=false  # enable hide titlebars
Mask=0
CONFIGS
if [ -n "$description" ] && [ -n "$current_file" ]; then
    add_desc "$description"
fi
if [ -n "$current_file" ]; then
    finish_file "$current_file"
fi

qdbus6 org.kde.KWin /KWin reconfigure >/dev/null 2>&1 || true

checklist_mark 1
section_header "Applying styles/colors"
styles_summary="
  ✓ glassd color scheme installed"

mkdir -p "$HOME/.local/share/color-schemes"
cat > "$HOME/.local/share/color-schemes/glassd.colors" <<'CSFILE'
[ColorEffects:Disabled]
Color=23,23,23
ColorAmount=0
ColorEffect=0
ContrastAmount=0.65
ContrastEffect=1
IntensityAmount=0.1
IntensityEffect=2

[ColorEffects:Inactive]
ChangeSelectionColor=false
Color=112,111,110
ColorAmount=0.025
ColorEffect=2
ContrastAmount=0.1
ContrastEffect=2
Enable=false
IntensityAmount=0
IntensityEffect=0

[Colors:Button]
BackgroundAlternate=105,105,105
BackgroundNormal=0,0,0,45
DecorationFocus=0,109,12,60
DecorationHover=175,175,175
ForegroundActive=120,120,120
