read -r REPLY < /dev/tty
case "$REPLY" in
    1) install_mode=local ;;
    2) install_mode=portable ;;
    *) install_mode=skip ;;
esac
SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
if [ "$install_mode" = local ]; then
    INSTALL_DIR="$HOME/.local/bin"
    left_border "$NEXT_ROW"
    printf '\033[%s;2H  Installing STTM GUI...\n' "$NEXT_ROW"
    NEXT_ROW=$((NEXT_ROW + 1))
    mkdir -p "$INSTALL_DIR"
    cp_or_fetch "sttm" "no" "$INSTALL_DIR" || true
    cp_or_fetch "blsw" "merge" "$INSTALL_DIR" || true
    chmod +x "$INSTALL_DIR/sttm" "$INSTALL_DIR/blsw" 2>/dev/null || true

    left_border "$NEXT_ROW"
    printf '\033[%s;2H  Installing icon...\n' "$NEXT_ROW"
    NEXT_ROW=$((NEXT_ROW + 1))
    mkdir -p "$HOME/.local/share/icons/hicolor/256x256/apps"
    icon_src=""
    if [ -f "$SCRIPT_DIR/icon.png" ]; then
        icon_src="$SCRIPT_DIR/icon.png"
    elif [ -n "$STTM_RAWBASE" ]; then
        fetch_file "/tmp/sttm-icon.png" "$STTM_RAWBASE/icon.png" && icon_src="/tmp/sttm-icon.png"
    fi
    if [ -n "$icon_src" ]; then
        if command -v convert >/dev/null 2>&1; then
            convert "$icon_src" -resize 256x256 "$HOME/.local/share/icons/hicolor/256x256/apps/sttm.png" >/dev/null 2>&1
        else
            cp "$icon_src" "$HOME/.local/share/icons/hicolor/256x256/apps/sttm.png" >/dev/null 2>&1
        fi
    else
        left_border "$NEXT_ROW"
        printf '\033[%s;2H  Warning: icon.png not found, skipping.\n' "$NEXT_ROW"
        NEXT_ROW=$((NEXT_ROW + 1))
    fi
    rm -f /tmp/sttm-icon.png

    left_border "$NEXT_ROW"
    printf '\033[%s;2H  Creating desktop entry...\n' "$NEXT_ROW"
    NEXT_ROW=$((NEXT_ROW + 1))
    mkdir -p "$HOME/.local/share/applications"
    cat > "$HOME/.local/share/applications/sttm.desktop" <<DESKTOP
[Desktop Entry]
Name=STTM
GenericName=Stoned Theme Manager
Comment=KDE theme manager with wallpaper-based color generation
Exec=$INSTALL_DIR/sttm
Icon=sttm
Terminal=false
Type=Application
Categories=Qt;KDE;System;Utility;
DESKTOP
    manager_summary="
  ✓ STTM installed to $INSTALL_DIR
  ✓ Desktop entry created"
elif [ "$install_mode" = portable ]; then
    PORT_DIR="$HOME/STTM"
    INSTALL_DIR="$PORT_DIR"
    left_border "$NEXT_ROW"
    printf '\033[%s;2H  Installing STTM GUI to %s...\n' "$NEXT_ROW" "$PORT_DIR"
    NEXT_ROW=$((NEXT_ROW + 1))
    mkdir -p "$PORT_DIR"
    cp_or_fetch "sttm" "no" "$PORT_DIR" || true
    cp_or_fetch "blsw" "merge" "$PORT_DIR" || true
    chmod +x "$PORT_DIR/sttm" "$PORT_DIR/blsw" 2>/dev/null || true

    left_border "$NEXT_ROW"
    printf '\033[%s;2H  Installing icon...\n' "$NEXT_ROW"
    NEXT_ROW=$((NEXT_ROW + 1))
    if [ -f "$SCRIPT_DIR/icon.png" ]; then
        cp "$SCRIPT_DIR/icon.png" "$PORT_DIR/sttm.png" 2>/dev/null || true
    elif [ -n "$STTM_RAWBASE" ]; then
        fetch_file "$PORT_DIR/sttm.png" "$STTM_RAWBASE/icon.png" || true
    fi

    left_border "$NEXT_ROW"
    printf '\033[%s;2H  Create desktop entry? [Y/n]: ' "$NEXT_ROW"
    read -r REPLY < /dev/tty
    case "$REPLY" in
        [nN]|[nN][oO]) create_desktop=false ;;
        *) create_desktop=true ;;
    esac
    if $create_desktop; then
        left_border "$NEXT_ROW"
        printf '\033[%s;2H  Creating desktop entry...\n' "$NEXT_ROW"
        NEXT_ROW=$((NEXT_ROW + 1))
        mkdir -p "$HOME/.local/share/applications"
        cat > "$HOME/.local/share/applications/sttm.desktop" <<DESKTOP
[Desktop Entry]
Name=STTM
GenericName=Stoned Theme Manager
Comment=KDE theme manager with wallpaper-based color generation
Exec=$PORT_DIR/sttm --portable
Icon=$PORT_DIR/sttm.png
Terminal=false
Type=Application
Categories=Qt;KDE;System;Utility;
DESKTOP
        manager_summary="
  ✓ STTM installed to $PORT_DIR/
  ✓ Desktop entry created"
    else
        manager_summary="
  ✓ STTM installed to $PORT_DIR/
  ✗ Desktop entry skipped"
    fi
else
    manager_summary="
  ✗ Skipped (user declined)"
fi

